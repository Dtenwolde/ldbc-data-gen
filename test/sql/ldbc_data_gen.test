# Java email-base normalization uses ICU NFD plus removal of the
# U+0300..U+036F Combining Diacritical Marks block, then Spark's dot cleanup.
query TT
SELECT name, ldbc_email_base(name) AS email_base
FROM (VALUES
  ('Renée'),
  ('José María'),
  ('Björk Guðmundsdóttir'),
  ('A  B...C'),
  ('Łukasz')
) AS input(name);
----
Renée	Renee
José María	Jose.Maria
Björk Guðmundsdóttir	Bjork.Guðmundsdottir
A  B...C	A.B.C
Łukasz	Łukasz

# Spark-compatible Person core generation covers block scheduling, RNG farm seeding,
# creation dates, birthdays, gender draws, random ids, and account-id composition.
query IIIIIIII
SELECT sequential_id, block_id, block_offset, creation_date_ms, id, birthday_ms, gender_code, random_id
FROM ldbcgen_person_core(sf := 0.003, rows := 5)
ORDER BY sequential_id;
