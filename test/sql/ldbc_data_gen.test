# Confirm table generation returns static dictionary and first dynamic row counts.
query TI
SELECT relation_name, row_count
FROM ldbcgen(sf := 0.003, schema := 'ldbc_counts')
WHERE relation_name IN ('Organisation', 'Person', 'Person_hasInterest_Tag', 'Person_studyAt_University',
                        'Person_workAt_Company', 'Person_knows_Person', 'Forum', 'Forum_hasMember_Person',
                        'Forum_hasTag_Tag', 'Comment', 'Comment_hasTag_Tag', 'Post', 'Post_hasTag_Tag',
                        'Person_likes_Post', 'Person_likes_Comment', 'Place', 'Tag', 'TagClass')
ORDER BY relation_name;
----
Comment	471
Comment_hasTag_Tag	655
Forum	381
Forum_hasMember_Person	1253
Forum_hasTag_Tag	1587
Organisation	7955
Person	50
Person_hasInterest_Tag	1256
Person_knows_Person	83
Person_likes_Comment	128
Person_likes_Post	364
Person_studyAt_University	42
Person_workAt_Company	103
Place	1460
Post	3189
Post_hasTag_Tag	182
Tag	16080
TagClass	71

# Confirm threaded person-core generation preserves deterministic row counts.
query TI
SELECT relation_name, row_count
FROM ldbcgen(sf := 0.003, schema := 'ldbc_counts_threads4', threads := 4)
WHERE relation_name IN ('Person', 'Person_hasInterest_Tag', 'Person_knows_Person', 'Post', 'Comment')
ORDER BY relation_name;
----
Comment	471
Person	50
Person_hasInterest_Tag	1256
Person_knows_Person	83
Post	3189

# Confirm the CALL contract creates DuckDB tables.
statement ok
CALL ldbcgen(sf := 0.003, schema := 'ldbc_test');

query I
SELECT COUNT(*)
FROM duckdb_tables()
WHERE schema_name = 'ldbc_test';
----
18

query I
SELECT COUNT(*)
FROM duckdb_columns()
WHERE schema_name = 'ldbc_test';
----
86

query TTTT
SELECT table_name, column_name, data_type, is_nullable
FROM duckdb_columns()
WHERE schema_name = 'ldbc_test'
  AND table_name = 'Post'
  AND column_name IN ('creationDate', 'id', 'imageFile')
ORDER BY column_index;
----
Post	creationDate	TIMESTAMP_MS	0
Post	id	BIGINT	0
Post	imageFile	VARCHAR	1

