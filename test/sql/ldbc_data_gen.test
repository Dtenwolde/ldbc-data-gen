query I
SELECT COUNT(*)
FROM ldbc_test.Post post
LEFT JOIN ldbc_test.Person creator ON post.CreatorPersonId = creator.id
LEFT JOIN ldbc_test.Forum forum ON post.ContainerForumId = forum.id
LEFT JOIN ldbc_test.Place country ON post.LocationCountryId = country.id
WHERE creator.id IS NULL
   OR forum.id IS NULL
   OR country.id IS NULL
   OR country.type <> 'Country'
   OR post.locationIP = ''
   OR post.browserUsed = ''
   OR post.length < 0;
----
0

query I
SELECT COUNT(*)
FROM ldbc_test.Post_hasTag_Tag edge
LEFT JOIN ldbc_test.Post post ON edge.PostId = post.id
LEFT JOIN ldbc_test.Tag tag ON edge.TagId = tag.id
WHERE post.id IS NULL
   OR tag.id IS NULL;
----
0

query I
SELECT COUNT(*)
FROM ldbc_test.Comment comment
LEFT JOIN ldbc_test.Person creator ON comment.CreatorPersonId = creator.id
LEFT JOIN ldbc_test.Place country ON comment.LocationCountryId = country.id
LEFT JOIN ldbc_test.Post parent_post ON comment.ParentPostId = parent_post.id
LEFT JOIN ldbc_test.Comment parent_comment ON comment.ParentCommentId = parent_comment.id
WHERE creator.id IS NULL
   OR country.id IS NULL
   OR country.type <> 'Country'
   OR comment.locationIP = ''
   OR comment.browserUsed = ''
   OR comment.content = ''
   OR comment.length <= 0
   OR (comment.ParentPostId IS NULL AND comment.ParentCommentId IS NULL)
   OR (comment.ParentPostId IS NOT NULL AND comment.ParentCommentId IS NOT NULL)
   OR (comment.ParentPostId IS NOT NULL AND parent_post.id IS NULL)
   OR (comment.ParentCommentId IS NOT NULL AND parent_comment.id IS NULL);
----
0

