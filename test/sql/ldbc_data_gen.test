query II
SELECT COUNT(*),
       COUNT(*) FILTER (WHERE email LIKE '%@%'
                         AND gender IN ('female', 'male')
                         AND language <> ''
                         AND firstName <> ''
                         AND lastName <> '')
FROM ldbc_test.Person;
----
50	50

query I
SELECT COUNT(*)
FROM ldbc_test.Person_hasInterest_Tag edge
LEFT JOIN ldbc_test.Person person ON edge.PersonId = person.id
LEFT JOIN ldbc_test.Tag tag ON edge.TagId = tag.id
WHERE person.id IS NULL
   OR tag.id IS NULL;
----
0

query I
SELECT COUNT(*)
FROM ldbc_test.Person_studyAt_University edge
LEFT JOIN ldbc_test.Person person ON edge.PersonId = person.id
LEFT JOIN ldbc_test.Organisation organisation ON edge.UniversityId = organisation.id
WHERE person.id IS NULL
   OR organisation.id IS NULL
   OR organisation.type <> 'University';
----
0

query I
