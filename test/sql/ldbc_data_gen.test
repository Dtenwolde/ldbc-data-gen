# name: test/sql/ldbc_data_gen.test
# description: test ldbc_data_gen extension
# group: [sql]

# Before we load the extension, this will fail
statement error
CALL ldbcgen(sf := 0.003);
----
Catalog Error: Table Function with name ldbcgen does not exist!

# Require statement will ensure this test is run with this extension loaded
require ldbc_data_gen

require parquet

# Spark-derived datagen configuration is resolved from pinned params_default.ini
# plus scale_factors.xml.
query TTTT
SELECT parameter, value, logical_type, source
FROM ldbcgen_config(sf := 0.003)
WHERE parameter IN ('scale_factor', 'num_persons', 'block_size', 'start_year', 'num_years', 'degree_distribution')
ORDER BY parameter;
----
block_size	10000	INTEGER	params_default.ini
degree_distribution	Facebook	VARCHAR	scale_factors.xml
num_persons	50	BIGINT	scale_factors.xml
num_years	3	INTEGER	scale_factors.xml
scale_factor	0.003	VARCHAR	scale_factors.xml
start_year	2010	INTEGER	scale_factors.xml

query TTT
SELECT parameter, value, source
FROM ldbcgen_config(sf := 1)
WHERE parameter IN ('num_persons', 'bulkload_portion', 'alpha')
ORDER BY parameter;
----
alpha	0.4	DatagenParams.java
bulkload_portion	0.97	LdbcDatagen.scala
num_persons	10620	scale_factors.xml

query TTT
SELECT parameter, value, source
FROM ldbcgen_config(sf := 1)
WHERE parameter IN ('max_emails', 'max_companies', 'prob_english', 'prob_second_lang')
ORDER BY parameter;
----
max_companies	5	params_default.ini:generator.maxEmails
max_emails	5	params_default.ini
prob_english	5	params_default.ini:generator.maxEmails
prob_second_lang	5	params_default.ini:generator.maxEmails

statement error
SELECT *
FROM ldbcgen_config(sf := 2);
