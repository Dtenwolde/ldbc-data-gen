# name: test/sql/ldbc_data_gen.test
# description: test ldbc_data_gen extension
# group: [sql]

# Before we load the extension, this will fail
statement error
CALL ldbcgen(sf := 0.003);
----
Catalog Error: Table Function with name ldbcgen does not exist!

# Require statement will ensure this test is run with this extension loaded
require ldbc_data_gen

# Java-compatible RNG vectors used by the Spark generator parity path.
query I
SELECT next_long
FROM ldbc_java_random(seed := 0, rows := 5)
ORDER BY draw_index;
----
-4962768465676381896
4437113781045784766
-6688467811848818630
-8292973307042192125
-7423979211207825555

query T
SELECT printf('%.17g', next_double)
FROM ldbc_java_random(seed := 0, rows := 5)
ORDER BY draw_index;
----
0.73096778737665702
0.24053641567148587
0.63741742535010826
0.55043700511763394
0.59754527779720179

query T
SELECT printf('%.9g', next_float)
FROM ldbc_java_random(seed := 0, rows := 5)
ORDER BY draw_index;
----
0.73096776
0.831440985
0.240536392
0.606345177
0.637417376

query I
SELECT next_int_100
FROM ldbc_java_random(seed := 0, rows := 10)
ORDER BY draw_index;
----
60
48
29
47
15
53
91
61
19
54

query I
SELECT next_int_max
FROM ldbc_java_random(seed := 0, rows := 5)
ORDER BY draw_index;
----
1569741360
1785505948
516548029
1302116447
1368843515

query I
SELECT next_long
FROM ldbc_java_random(seed := 53223436, rows := 5)
ORDER BY draw_index;
----
-4512997451346958241
-6473059946999388453
-1813421515445810181
-4477688948489879377
-3180555934360176434

statement error
SELECT *
FROM ldbc_java_random(rows := -1);
----
Binder Error: ldbc_java_random parameter rows must be non-negative

# Confirm table generation returns static dictionary row counts.
query TI
SELECT relation_name, row_count
FROM ldbcgen(sf := 0.003, schema := 'ldbc_counts')
WHERE relation_name IN ('Organisation', 'Place', 'Tag', 'TagClass')
ORDER BY relation_name;
----
Organisation	7955
Place	1460
Tag	16080
TagClass	71

# Confirm the CALL contract creates DuckDB tables.
statement ok
CALL ldbcgen(sf := 0.003, schema := 'ldbc_test');

query I
SELECT COUNT(*)
FROM duckdb_tables()
WHERE schema_name = 'ldbc_test';
----
18

query I
SELECT COUNT(*)
FROM duckdb_columns()
WHERE schema_name = 'ldbc_test';
----
86

query TTTT
SELECT table_name, column_name, data_type, is_nullable
FROM duckdb_columns()
WHERE schema_name = 'ldbc_test'
  AND table_name = 'Post'
  AND column_name IN ('creationDate', 'id', 'imageFile')
ORDER BY column_index;
----
Post	creationDate	TIMESTAMP_MS	0
Post	id	BIGINT	0
Post	imageFile	VARCHAR	1

query TI
SELECT 'Organisation' AS relation_name, COUNT(*) AS row_count FROM ldbc_test.Organisation
UNION ALL SELECT 'Place', COUNT(*) FROM ldbc_test.Place
UNION ALL SELECT 'Tag', COUNT(*) FROM ldbc_test.Tag
UNION ALL SELECT 'TagClass', COUNT(*) FROM ldbc_test.TagClass
ORDER BY relation_name;
----
Organisation	7955
Place	1460
Tag	16080
TagClass	71

query I
SELECT COUNT(*)
FROM ldbc_test.Place child
LEFT JOIN ldbc_test.Place parent
  ON child.PartOfPlaceId = parent.id
WHERE child.PartOfPlaceId IS NOT NULL
  AND parent.id IS NULL;
----
0

query I
SELECT COUNT(*)
FROM ldbc_test.Tag tag
LEFT JOIN ldbc_test.TagClass tag_class
  ON tag.TypeTagClassId = tag_class.id
WHERE tag_class.id IS NULL;
----
0

query I
SELECT COUNT(*)
FROM ldbc_test.Organisation organisation
LEFT JOIN ldbc_test.Place place
  ON organisation.LocationPlaceId = place.id
WHERE place.id IS NULL;
----
0

statement error
CALL ldbcgen(sf := 0.003, schema := 'ldbc_test');
----
Catalog Error: Table with name "Organisation" already exists!

statement ok
CALL ldbcgen(sf := 0.003, schema := 'ldbc_test', overwrite := true);

query TTTTTT
SELECT relation_name, path, row_count, checksum, format, status
FROM ldbcgen(sf := 0.003, target := 'files', output_dir := 'out/sf0.003', format := 'parquet', overwrite := false);
----
ldbc_snb_bi_static	out/sf0.003	NULL	NULL	parquet	planned

statement error
CALL ldbcgen(sf := 0);
----
Binder Error: ldbcgen parameter sf must be greater than zero

statement error
CALL ldbcgen(sf := 1, format := 'json');
----
Binder Error: ldbcgen parameter format must be either 'parquet' or 'csv'

statement error
CALL ldbcgen(sf := 1, target := 'files');
----
Binder Error: ldbcgen parameter output_dir must be set when target is 'files'

statement error
CALL ldbcgen(sf := 1, target := 'memory');
----
Binder Error: ldbcgen parameter target must be either 'tables' or 'files'

# Schema-only generation exposes the BI static schema without writing data.
query I
SELECT COUNT(DISTINCT relation_name)
FROM ldbcgen_schema();
----
18

query I
SELECT COUNT(*)
FROM ldbcgen_schema();
----
86

query TTTTTTTT
SELECT entity_path, kind, snapshot_path, column_index, column_name, nullable, logical_type, primary_key
FROM ldbcgen_schema(format := 'csv')
WHERE relation_name = 'Post'
ORDER BY column_index
LIMIT 3;
----
dynamic/Post	dynamic_node	graphs/csv/bi/composite-merged-fk/initial_snapshot/dynamic/Post	0	creationDate	false	TIMESTAMP_MS	id
dynamic/Post	dynamic_node	graphs/csv/bi/composite-merged-fk/initial_snapshot/dynamic/Post	1	id	false	BIGINT	id
dynamic/Post	dynamic_node	graphs/csv/bi/composite-merged-fk/initial_snapshot/dynamic/Post	2	imageFile	true	VARCHAR	id

query TTT
SELECT column_name, logical_type, primary_key
FROM ldbcgen_schema()
WHERE relation_name = 'Person_knows_Person'
ORDER BY column_index;
----
creationDate	TIMESTAMP_MS	Person1Id,Person2Id
Person1Id	BIGINT	Person1Id,Person2Id
Person2Id	BIGINT	Person1Id,Person2Id

statement error
SELECT * FROM ldbcgen_schema(format := 'json');
----
Binder Error: ldbcgen_schema parameter format must be either 'parquet' or 'csv'
