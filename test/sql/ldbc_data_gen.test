0	0	0	1311716494142	19791209299968	478051200000	1	87
1	0	1	1289663409443	10995116277761	536803200000	1	30
2	0	2	1349128911812	35184372088834	626745600000	0	49
3	0	3	1341276916938	30786325577731	366076800000	1	58
4	0	4	1333102272788	28587302322180	486518400000	1	16

