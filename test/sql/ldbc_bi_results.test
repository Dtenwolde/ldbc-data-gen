# name: test/sql/ldbc_bi_results.test
# description: regression results for all LDBC SNB BI query pragmas
# group: [sql]

require ldbc_data_gen

# This deterministic SF0.003 fixture is a regression oracle for the DuckDB
# implementation. It is intentionally separate from the audited SF10 LDBC
# cross-validation data, which is too large for the regular extension CI job.
statement ok
CALL ldbcgen(sf := 0.003, schema := 'ldbc_bi_results');

# Q1: Posting summary
query IIIIRIR
PRAGMA ldbc_bi(1, schema = 'ldbc_bi_results', datetime = TIMESTAMP '2011-12-01');
----
42 values hashing to 13624ace28f2b60123fb10d4a78c376d

# Q2: Tag evolution
query TIII
PRAGMA ldbc_bi(2, schema = 'ldbc_bi_results', date = TIMESTAMP '2012-06-01', tag_class = 'MusicalArtist');
----
400 values hashing to 131ec47d680c2960a9de69e4b2b8220a

# Q3: Popular topics in a country
query ITTII
PRAGMA ldbc_bi(3, schema = 'ldbc_bi_results', tag_class = 'MusicalArtist', country = 'Burma');
----
5 values hashing to 68fcbedebf62b6b26f6a25344e835c61

